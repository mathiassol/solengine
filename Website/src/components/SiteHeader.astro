---
// Shared site-wide header — used by BaseLayout AND Starlight override
---

<header class="site-nav">
	<div class="wrap">
		<a href="/" class="wordmark">SOLENGINE</a>
		<nav>
			<a href="/docs/">Docs</a>
			<a href="/forum">Forum</a>
			<a href="/download" class="nav-dl">Download</a>
			<button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" title="Toggle light/dark">
				<!-- sun icon (shown in dark mode to switch to light) -->
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
					<line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</svg>
				<!-- moon icon (shown in light mode to switch to dark) -->
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
			</button>
		</nav>
	</div>
</header>

<script>
	(function () {
		const html   = document.documentElement;
		const btn    = document.getElementById('theme-toggle');
		const KEY    = 'starlight-theme';

		function applyTheme(t: string) {
			html.dataset.theme = t;
			// keep Starlight's own data-theme in sync on docs pages
			html.setAttribute('data-theme', t);
			localStorage.setItem(KEY, t);
		}

		function currentTheme(): string {
			return html.dataset.theme === 'light' ? 'light' : 'dark';
		}

		btn?.addEventListener('click', () => {
			applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
		});

		// React to external theme changes (Starlight might also set it)
		new MutationObserver(() => {
			// nothing — icon visibility is pure CSS based on data-theme
		}).observe(html, { attributes: true, attributeFilter: ['data-theme'] });
	})();
</script>

<style>
	.wrap { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
	.site-nav {
		position: sticky; top: 0; z-index: 9999;
		background: var(--bg, #0d0d0d);
		border-bottom: 1px solid var(--border, #262626);
		/* map Starlight vars → our vars so this works inside Starlight too */
		--bg:     var(--sl-color-bg,     #0d0d0d);
		--border: var(--sl-color-hairline, #262626);
		--text:   var(--sl-color-text,   #e8e8e8);
		--muted:  var(--sl-color-gray-3, #888888);
		--accent: var(--sl-color-accent, #d4a840);
	}
	.site-nav .wrap {
		height: 52px; display: flex; align-items: center; justify-content: space-between;
	}
	.wordmark {
		font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em;
		color: var(--text, #e8e8e8);
	}
	nav { display: flex; align-items: center; gap: 2rem; font-size: 0.78rem; letter-spacing: 0.06em; }
	nav a { color: var(--muted, #888888); transition: color 0.15s; }
	nav a:hover { color: var(--text, #e8e8e8); }
	.nav-dl { color: var(--accent, #d4a840) !important; }

	/* theme toggle button */
	.theme-btn {
		background: none; border: none; cursor: pointer; padding: 0;
		color: var(--muted, #888888); transition: color 0.15s;
		display: flex; align-items: center; line-height: 1;
	}
	.theme-btn:hover { color: var(--text, #e8e8e8); }

	/* show sun in dark mode, moon in light mode */
	:root:not([data-theme='light']) .icon-moon { display: none; }
	[data-theme='light'] .icon-sun { display: none; }
</style>
